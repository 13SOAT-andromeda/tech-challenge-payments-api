# Token TEST-... → sandbox | Token APP_USR-... → produção
MERCADOPAGO_PUBLIC_KEY=your-mercadopago-public-key
MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
# Chave gerada em: Suas Integrações → (sua app) → Webhooks → Chave secreta
MERCADOPAGO_WEBHOOK_SECRET=your-mercadopago-webhook-secret

# URLs de retorno após pagamento (opcional — se não definido, auto_return não é enviado ao MP)
BACK_URL_SUCCESS=https://your-app.com/payment/success
BACK_URL_FAILURE=https://your-app.com/payment/failure
BACK_URL_PENDING=https://your-app.com/payment/pending

SQS_QUEUE_URL_ORDER_EVENTS=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/payment-order-events-queue
SNS_TOPIC_ARN_PAYMENT=arn:aws:sns:us-east-1:ACCOUNT_ID:payment-events
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Usado apenas ao rodar fora do docker compose (dentro do compose usa postgres interno)
DATABASE_URL=postgres://payments:payments@localhost:5432/payments?sslmode=disable

PORT=8080
